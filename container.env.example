# ============================================================
# Gemensams — container.env.example
# Copy to container.env and fill in real values.
# NEVER commit container.env — it contains secrets.
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-db-password

# ---- App — database connections ----
POSTGRES_PRISMA_URL=postgresql://postgres:change-me-db-password@db/postgres
POSTGRES_URL_NON_POOLING=postgresql://postgres:change-me-db-password@db/postgres

# ---- App — general ----
NEXT_PUBLIC_BASE_URL=https://gemensams.krut.it

# ---- Shared-password gate ----
# APP_PASSWORD: the password users type on the /login page
# APP_SECRET:   random secret used to sign session cookies (generate with: openssl rand -hex 32)
APP_PASSWORD=change-me-app-password
APP_SECRET=generate-a-long-random-string-here

# ---- MinIO (S3-compatible object storage) ----
MINIO_ROOT_USER=gemensams
MINIO_ROOT_PASSWORD=change-me-minio-password

# ---- App — S3 / file uploads ----
# These point the Next.js app at the MinIO service inside the compose network.
NEXT_PUBLIC_ENABLE_EXPENSE_DOCUMENTS=true
S3_UPLOAD_KEY=gemensams
S3_UPLOAD_SECRET=change-me-minio-password
S3_UPLOAD_BUCKET=receipts
S3_UPLOAD_REGION=us-east-1
S3_UPLOAD_ENDPOINT=http://minio:9000
