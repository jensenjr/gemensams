# ============================================================
# Gemensams — container.env.example  (Docker Compose / Coolify)
#
# Local self-hosting:  copy to container.env, fill values, then:  npm run start-container
# Coolify:             set these as Environment Variables in the Coolify UI.
#                      Do NOT commit container.env — it holds secrets (it is gitignored).
#
# The stack BOOTS with zero config (compose has safe defaults for the internal
# DB/MinIO passwords, which are not publicly exposed). For a real deployment you
# should still override the security-sensitive ones below. The Postgres URLs and
# S3 credentials are CONSTRUCTED in compose.yaml, so you don't set them here.
# IMPORTANT: set POSTGRES_PASSWORD BEFORE the first deploy — Postgres only applies
# it when the data volume is first created.
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-db-password        # override before first deploy (default: gemensams_db_pw)
POSTGRES_DB=postgres

# ---- App ----
NEXT_PUBLIC_BASE_URL=https://gemensams.krut.it
APP_PASSWORD=change-me-app-password            # set this — the /login password (no default; login unusable until set)
APP_SECRET=generate-a-long-random-string       # set this — signs session cookies: openssl rand -hex 32

# ---- MinIO (S3-compatible object storage) ----
MINIO_ROOT_USER=gemensams
MINIO_ROOT_PASSWORD=change-me-minio-password   # override for security (default: gemensams_minio_pw)

# ---- Receipt uploads (Phase 2 — leave disabled for now) ----
# Enabling needs a PUBLIC S3 endpoint so browsers can load images; wire that in Phase 2.
NEXT_PUBLIC_ENABLE_EXPENSE_DOCUMENTS=false
S3_UPLOAD_BUCKET=receipts
S3_UPLOAD_REGION=us-east-1
# S3_UPLOAD_ENDPOINT defaults to http://minio:9000 (compose-internal). Set a public URL in Phase 2.
